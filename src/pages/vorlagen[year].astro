---
import LegacyRedirectPage from "../components/LegacyRedirectPage.astro";
import { getAvailableYears } from "../shared/data";
import { buildPapersUrl } from "../shared/utils";

export async function getStaticPaths() {
  const availableYears = await getAvailableYears();
  return availableYears.map((year) => ({ params: { year } }));
}

const baseUrl = import.meta.env.BASE_URL;
const year = Astro.params.year ?? "";
const targetUrl = buildPapersUrl(baseUrl, year);
---

<LegacyRedirectPage targetUrl={targetUrl} />
