---
import Layout from "../layouts/Layout.astro";
import PaperListingPage from "../components/PaperListingPage.astro";
import { loadPapers, loadOrganizations, loadMeetings } from "../shared/data";
import { buildPaperFilters } from "../shared/paper-filter-utils";

const [papers, organizationsById, meetingsById] = await Promise.all([
  loadPapers(),
  loadOrganizations(),
  loadMeetings(),
]);

const { metadataByPaperReference, filterOptions } = buildPaperFilters(
  papers,
  organizationsById,
  meetingsById,
);
---

<Layout title="Vorlagen">
  <PaperListingPage
    title="Vorlagen"
    papers={papers}
    filterMetadataByReference={metadataByPaperReference}
    filterOptions={filterOptions}
  />
</Layout>
