---
import Layout from "../layouts/Layout.astro";
import PaperListPage from "../components/PaperListPage.astro";
import { loadPaperFilterModel } from "../shared/paper-filters";

const { papers, valuesByReference, options } = await loadPaperFilterModel();
---

<Layout title="Vorlagen">
  <PaperListPage
    title="Vorlagen"
    papers={papers}
    filterValuesByReference={valuesByReference}
    filterOptions={options}
  />
</Layout>
