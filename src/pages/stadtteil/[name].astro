---
import Layout from "../../layouts/Layout.astro";
import PaperListPage from "../../components/PaperListPage.astro";
import StadtteilHint from "../../components/StadtteilHint.astro";
import {
  loadPapers,
  loadOrganizations,
  loadMeetings,
  getAvailableDistricts,
} from "../../shared/data";
import { buildPaperFilterModel } from "../../shared/paper-filters";
import { slugify } from "../../shared/utils";

export async function getStaticPaths() {
  const districtNames = await getAvailableDistricts();
  return districtNames.map((districtName) => ({
    params: { name: slugify(districtName) },
    props: { districtName },
  }));
}

const { districtName } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const [allPapers, organizationsById, meetingsById] = await Promise.all([
  loadPapers(),
  loadOrganizations(),
  loadMeetings(),
]);

const papers = allPapers.filter((paper) =>
  paper.stadtteile.some((paperDistrict) => paperDistrict === districtName),
);

const { valuesByReference, options } = buildPaperFilterModel(
  papers,
  organizationsById,
  meetingsById,
);
---

<Layout title={districtName}>
  <PaperListPage
    title={districtName}
    papers={papers}
    filterValuesByReference={valuesByReference}
    filterOptions={options}
  >
    <p slot="intro" class="subtitle">
      {papers.length} Vorlagen &middot;
      <a href={`${baseUrl}stadtteile`} class="back-link">Alle Stadtteile</a>
    </p>
    <StadtteilHint slot="intro" />
  </PaperListPage>
</Layout>

<style>
  .subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: 14px;
  }

  .back-link {
    color: var(--color-link);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
