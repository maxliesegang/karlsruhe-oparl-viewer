{
  "name": "karlsruhe-oparl-viewer",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "predev": "node scripts/ensure-pagefind-index.mjs",
    "dev": "astro dev",
    "data:setup": "node scripts/setup-local-data.mjs",
    "dev:local": "DATA_SOURCE=local astro dev",
    "prestart": "node scripts/ensure-pagefind-index.mjs",
    "start": "astro dev",
    "build": "astro build",
    "build:quick": "SKIP_PAGEFIND=1 astro build",
    "build:local": "DATA_SOURCE=local astro build",
    "build:local:quick": "DATA_SOURCE=local SKIP_PAGEFIND=1 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "npx prettier . --write"
  },
  "dependencies": {
    "astro": "^7.1.1",
    "astro-pagefind": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1"
  }
}
